    "components": {
        "schemas": {
            "PostoSearchResponse": {
                "required": [
                    "q",
                    "count",
                    "postos"
                ],
                "properties": {
                    "q": {
                        "description": "Termo pesquisado",
                        "type": "string",
                        "example": "shell"
                    },
                    "count": {
                        "description": "Número de resultados devolvidos",
                        "type": "integer",
                        "example": 2
                    },
                    "postos": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/PostoPublic"
                        }
                    }
                },
                "type": "object"
            },
            "PostoPublicPaginatedResponse": {
                "properties": {
                    "postos": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/PostoPublic"
                        }
                    },
                    "page": {
                        "type": "integer",
                        "example": 1
                    },
                    "per_page": {
                        "type": "integer",
                        "example": 10
                    },
                    "total": {
                        "type": "integer",
                        "example": 25
                    },
                    "last_page": {
                        "type": "integer",
                        "example": 3
                    }
                },
                "type": "object"
            },
            "PostoPublic": {
                "properties": {
                    "id": {
                        "type": "string",
                        "example": "1"
                    },
                    "nome": {
                        "type": "string",
                        "example": "Posto Shell"
                    },
                    "endereco": {
                        "type": "string",
                        "example": "Av. 4 de Fevereiro, 123"
                    },
                    "tipo": {
                        "type": "string",
                        "example": "combustivel"
                    },
                    "coordinates": {
                        "properties": {
                            "latitude": {
                                "type": "number",
                                "format": "float",
                                "example": -8.8383
                            },
                            "longitude": {
                                "type": "number",
                                "format": "float",
                                "example": 13.2344
                            }
                        },
                        "type": "object"
                    },
                    "preco": {
                        "type": "string",
                        "example": "320 Kz/L",
                        "nullable": true
                    },
                    "precoPremium": {
                        "type": "string",
                        "example": "340 Kz/L",
                        "nullable": true
                    },
                    "combustivel": {
                        "type": "string",
                        "example": "Gasolina",
                        "nullable": true
                    },
                    "status": {
                        "type": "string",
                        "example": "aberto"
                    },
                    "hours24": {
                        "type": "boolean",
                        "example": true
                    },
                    "image": {
                        "type": "string",
                        "nullable": true
                    },
                    "services": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "example": [
                            "Wifi",
                            "Lavagem",
                            "Loja de Conveniência"
                        ]
                    }
                },
                "type": "object"
            },
            "Post": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Posto Central"
                    },
                    "address": {
                        "type": "string",
                        "nullable": true
                    },
                    "latitude": {
                        "type": "number",
                        "format": "float",
                        "nullable": true
                    },
                    "longitude": {
                        "type": "number",
                        "format": "float",
                        "nullable": true
                    },
                    "admin_id": {
