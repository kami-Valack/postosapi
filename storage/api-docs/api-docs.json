        "/postos/search": {
            "get": {
                "tags": [
                    "Postos Públicos"
                ],
                "summary": "Pesquisar postos (público, rápido)",
                "description": "**Rota pública** — não requer `Authorization`.\n\nPesquisa em `nome`, `endereco` e `combustivel` (apenas postos activos).\n\n- `q`: obrigatório, mínimo 2 caracteres\n- `limit`: opcional (default 20, máximo 50)\n- Filtros opcionais: `tipo`, `combustivel`, `status`\n- Resposta em cache ~60 segundos\n\nExemplo: `GET /api/postos/search?q=shell&status=aberto&limit=10`",
                "operationId": "8fb713bcd00ed77ef0ad5ef91996b491",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "description": "Termo de pesquisa (nome, morada ou combustível)",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "shell",
                            "minLength": 2
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Máximo de resultados",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 20,
                            "default": 20,
                            "maximum": 50
                        }
                    },
                    {
                        "name": "tipo",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "combustivel"
                        }
                    },
                    {
                        "name": "combustivel",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "Gasolina"
                        }
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "aberto"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de postos que correspondem à pesquisa",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PostoSearchResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validação falhou (ex.: q em falta ou &lt; 2 caracteres)",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "The q field is required."
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/postos": {
            "get": {
                "tags": [
                    "Postos Públicos"
                ],
                "summary": "Listar postos (público)",
                "description": "**Rota pública** — não requer `Authorization`.\n\n- Sem parâmetros: todos os postos activos (array)\n- `?id=1`: um posto (`PostoPublic`)\n- `?page=2`: paginação, 10 por página (`PostoPublicPaginatedResponse`)\n\nPara pesquisa textual use `GET /postos/search?q=...`.",
                "operationId": "0d8c4c8337fe50c98d64db4223fe70c5",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "description": "ID do posto",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Número da página (10 postos por página)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 1,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Posto único, lista ou página paginada",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "oneOf": [
                                        {
                                            "$ref": "#/components/schemas/PostoPublic"
                                        },
                                        {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/PostoPublic"
                                            }
                                        },
                                        {
                                            "$ref": "#/components/schemas/PostoPublicPaginatedResponse"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Posto não encontrado"
                    }
                }
            }
        },
